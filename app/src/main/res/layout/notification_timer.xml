<?xml version="1.0" encoding="utf-8"?>
<!-- Custom collapsed/expanded content for the running-timer notification.
     The Chronometer is the star: OS-rendered and OS-ticked (countDown mode),
     so the big remaining-time display still costs zero process time. Text
     appearances come from androidx.core's notification compat styles so the
     colors adapt to light/dark notification backgrounds across OEM skins. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <Chronometer
        android:id="@+id/timer_chronometer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Compat.Notification.Title"
        android:textSize="28sp"
        android:fontFamily="sans-serif-medium" />

    <TextView
        android:id="@+id/timer_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="@style/TextAppearance.Compat.Notification"
        android:maxLines="1"
        android:ellipsize="end" />
</LinearLayout>
